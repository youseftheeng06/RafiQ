# Copy to Render / Railway service environment (or `.env` for local overrides — never commit real secrets).

SPRING_PROFILES_ACTIVE=prod

# PostgreSQL — usually auto-injected as DATABASE_URL; or jdbc:postgresql://...
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# Alternative: PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD

# Must match where your HTML is served (OAuth redirect targets this site).
APP_FRONTEND_BASE_URL=https://your-app.netlify.app

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-4.5-air:free

ZEGOCLOUD_APP_ID=
ZEGOCLOUD_SERVER_SECRET=
